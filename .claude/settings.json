{
  "enabledPlugins": {
    "ork@orchestkit": true
  },
  "enabledMcpjsonServers": ["serena"],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'bash \"$(git rev-parse --show-toplevel)/.claude/hooks/superpowers-session-start.sh\"'",
            "timeout": 10,
            "statusMessage": "Loading superpowers..."
          },
          {
            "type": "command",
            "command": "bash -c 'node \"$(git rev-parse --show-toplevel)/.claude/hooks/caveman-activate.js\"'",
            "timeout": 5,
            "statusMessage": "Loading caveman mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"$(git rev-parse --show-toplevel)/.claude/hooks/caveman-mode-tracker.js\"'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
